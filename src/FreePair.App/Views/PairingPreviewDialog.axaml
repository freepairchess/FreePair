<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FreePair.App.ViewModels"
        mc:Ignorable="d" d:DesignWidth="780" d:DesignHeight="560"
        x:Class="FreePair.App.Views.PairingPreviewDialog"
        x:DataType="vm:PairingPreviewViewModel"
        Title="Preview pairings"
        Width="780"
        SizeToContent="Height"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel Margin="16">

        <!-- ===== header ===== -->
        <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,10">
            <TextBlock x:Name="HeaderText"
                       FontSize="14"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Review the proposed pairings before committing this round. Use the buttons on each row to swap colours, give a player a late ½-pt bye, or swap two boards' opponents."
                       Foreground="Gray"
                       FontSize="11"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ===== unresolved-conflict warnings ===== -->
        <Border DockPanel.Dock="Top"
                Background="#FFF8E1"
                BorderBrush="#E0C460"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Margin="0,0,0,10"
                IsVisible="{Binding Conflicts.Count}">
            <StackPanel Spacing="2">
                <TextBlock Text="Unresolvable pairing-constraint warnings"
                           FontWeight="SemiBold"
                           Foreground="#7A5A00"/>
                <ItemsControl ItemsSource="{Binding Conflicts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Foreground="#7A5A00"
                                       FontSize="11"
                                       Margin="6,0,0,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ===== board-swap helper ===== -->
        <Border DockPanel.Dock="Top"
                Background="#F0F4FF"
                BorderBrush="#C7D4F2"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10"
                Margin="0,0,0,10">
            <StackPanel Spacing="4">
                <TextBlock FontWeight="SemiBold"
                           Text="Drag-and-drop to swap opponents"/>
                <TextBlock FontSize="11" Foreground="DimGray" TextWrapping="Wrap"
                           Text="Drag a player onto another player to swap them between two boards. Same-colour drops swap opponents (colours preserved). Cross-colour drops literally exchange positions (the two players' colours flip). Any swap that recreates a previously-played game or shifts colours unexpectedly is flagged inline with a warning note until results are entered. Pairings only publish to NA Chess Hub after you press Commit; cancelled previews are discarded entirely."/>
                <TextBlock x:Name="SwapErrorText"
                           Foreground="DarkRed"
                           FontSize="11"
                           TextWrapping="Wrap"
                           IsVisible="{Binding $self.Text.Length}"/>
            </StackPanel>
        </Border>

        <!-- ===== accept/cancel ===== -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,10,0,0">
            <Button Content="Cancel pairing"
                    Click="OnCancel"
                    MinWidth="120"/>
            <Button Content="Commit round"
                    Click="OnCommit"
                    IsDefault="True"
                    MinWidth="120"
                    Background="#0E5DAA"
                    Foreground="White"/>
        </StackPanel>

        <!-- ===== board list ===== -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PairingPreviewRow">
                        <Border BorderBrush="#DDDDDD"
                                BorderThickness="0,0,0,1"
                                Padding="6,4">
                            <StackPanel Spacing="2">
                                <Grid ColumnDefinitions="Auto,2*,Auto,2*,Auto,Auto,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Board, StringFormat='Bd {0}'}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Width="56"/>
                                <!-- White-player drag chip: PointerPressed
                                     starts a drag; same chip accepts a drop
                                     from another white chip. Tag carries the
                                     PairingPreviewRow so the drop handler
                                     can read board + colour. -->
                                <Border Grid.Column="1"
                                        Background="#F5F8FF"
                                        BorderBrush="#BFD0EE"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Padding="6,3"
                                        Margin="6,0"
                                        Cursor="Hand"
                                        Tag="W"
                                        PointerPressed="OnPlayerChipPointerPressed"
                                        DragDrop.AllowDrop="True">
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="W: #"/>
                                        <Run Text="{Binding WhitePair}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding WhiteName}"/>
                                    </TextBlock>
                                </Border>
                                <TextBlock Grid.Column="2"
                                           Text="vs"
                                           VerticalAlignment="Center"
                                           Margin="6,0"
                                           Foreground="Gray"/>
                                <Border Grid.Column="3"
                                        Background="#F5F5F5"
                                        BorderBrush="#CCCCCC"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Padding="6,3"
                                        Margin="6,0"
                                        Cursor="Hand"
                                        Tag="B"
                                        PointerPressed="OnPlayerChipPointerPressed"
                                        DragDrop.AllowDrop="True">
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="B: #"/>
                                        <Run Text="{Binding BlackPair}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding BlackName}"/>
                                    </TextBlock>
                                </Border>
                                <Button Grid.Column="4"
                                        Content="↔ Colors"
                                        Click="OnRowSwapColors"
                                        Tag="{Binding}"
                                        Margin="4,0"
                                        Padding="6,2"
                                        FontSize="11"/>
                                <Button Grid.Column="5"
                                        Content="½ to W"
                                        Click="OnRowHalfByeWhite"
                                        Tag="{Binding}"
                                        Margin="4,0"
                                        Padding="6,2"
                                        FontSize="11"
                                        ToolTip.Tip="Give white player a half-point bye; black gets a full-point bye."/>
                                <Button Grid.Column="6"
                                        Content="½ to B"
                                        Click="OnRowHalfByeBlack"
                                        Tag="{Binding}"
                                        Margin="4,0"
                                        Padding="6,2"
                                        FontSize="11"
                                        ToolTip.Tip="Give black player a half-point bye; white gets a full-point bye."/>
                                </Grid>
                                <!-- Per-pairing TD note (e.g. forced
                                     swap warning); hidden when null. -->
                                <TextBlock Text="{Binding Note}"
                                           Foreground="DarkOrange"
                                           FontSize="11"
                                           Margin="62,0,0,0"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding Note, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
