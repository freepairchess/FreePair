<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FreePair.App.ViewModels"
             xmlns:enums="using:FreePair.Core.Tournaments.Enums"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="780" d:DesignHeight="720"
             x:Class="FreePair.App.Views.EventConfigView"
             x:DataType="vm:EventConfigViewModel">

    <ScrollViewer>
        <StackPanel Margin="0" Spacing="12">

            <TextBlock Text="Event configuration" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Text="Edit event-level metadata and defaults. Changes are applied as one immutable batch; they persist to the .sjson file on the next auto-save."
                       Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>

            <!-- ============ Basics ============ -->
            <Border Background="#F6F6F6" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="16">
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto">
                    <Grid.Styles>
                        <Style Selector="TextBlock.label">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="0,6,12,6"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                        <Style Selector="TextBox,DatePicker,ComboBox,NumericUpDown">
                            <Setter Property="Margin" Value="0,4"/>
                        </Style>
                    </Grid.Styles>
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Title"/>
                    <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Title}" Watermark="Event title"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Start date"/>
                    <DatePicker Grid.Row="1" Grid.Column="1" SelectedDate="{Binding StartDate}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="End date"/>
                    <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding EndDate}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="Time control"/>
                    <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding TimeControl}" Watermark="e.g. G/45;d5"/>
                </Grid>
            </Border>

            <!-- ============ Address ============ -->
            <TextBlock Text="Venue" FontWeight="SemiBold" Margin="0,6,0,0"/>
            <Border Background="#F6F6F6" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="16">
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                    <Grid.Styles>
                        <Style Selector="TextBlock.label">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="0,6,12,6"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                        <Style Selector="TextBox"><Setter Property="Margin" Value="0,4"/></Style>
                    </Grid.Styles>
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Address"/>
                    <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding EventAddress}" Watermark="Street address"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="City"/>
                    <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding EventCity}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="State / Province"/>
                    <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding EventState}" Watermark="e.g. OR"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="ZIP / Postal code"/>
                    <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding EventZipCode}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="Country"/>
                    <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding EventCountry}" Watermark="USA / Canada / …"/>
                </Grid>
            </Border>

            <!-- ============ Classifications ============ -->
            <TextBlock Text="Classification" FontWeight="SemiBold" Margin="0,6,0,0"/>
            <Border Background="#F6F6F6" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="16">
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                    <Grid.Styles>
                        <Style Selector="TextBlock.label">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="0,6,12,6"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                        <Style Selector="ComboBox">
                            <Setter Property="Margin" Value="0,4"/>
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        </Style>
                    </Grid.Styles>
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Event format"/>
                    <ComboBox  Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AvailableEventFormats}" SelectedItem="{Binding EventFormat}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Event type"/>
                    <ComboBox  Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AvailableEventTypes}" SelectedItem="{Binding EventType}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Pairing rule"/>
                    <ComboBox  Grid.Row="2" Grid.Column="1" ItemsSource="{Binding AvailablePairingRules}" SelectedItem="{Binding PairingRule}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="Time control type"/>
                    <ComboBox  Grid.Row="3" Grid.Column="1" ItemsSource="{Binding AvailableTimeControlTypes}" SelectedItem="{Binding TimeControlType}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="Rating system"/>
                    <ComboBox  Grid.Row="4" Grid.Column="1" ItemsSource="{Binding AvailableRatingTypes}" SelectedItem="{Binding RatingType}"/>
                </Grid>
            </Border>

            <!-- ============ Scheduling ============ -->
            <TextBlock Text="Scheduling" FontWeight="SemiBold" Margin="0,6,0,0"/>
            <Border Background="#F6F6F6" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="16">
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                    <Grid.Styles>
                        <Style Selector="TextBlock.label">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="0,6,12,6"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                        <Style Selector="TextBox,NumericUpDown,ComboBox">
                            <Setter Property="Margin" Value="0,4"/>
                        </Style>
                    </Grid.Styles>
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Rounds planned"/>
                    <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding RoundsPlanned}" Minimum="0" Maximum="30" Increment="1" HorizontalAlignment="Left" MinWidth="140"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Half-pt byes allowed"/>
                    <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding HalfPointByesAllowed}" Minimum="0" Maximum="10" Increment="1" HorizontalAlignment="Left" MinWidth="140"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Time zone"/>
                    <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding TimeZone}" Watermark="Windows id, e.g. Pacific Standard Time"/>

                    <!-- Organiser: three fields. ID + ID type are split so
                         the TD can record whether this is a USCF affiliate,
                         FIDE organiser, etc. (see UserIDType enum). -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="Organizer name"/>
                    <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding OrganizerName}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="Organizer ID"/>
                    <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding OrganizerId}" Watermark="e.g. A10034449"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Classes="label" Text="Organizer ID type"/>
                    <ComboBox  Grid.Row="5" Grid.Column="1"
                               ItemsSource="{Binding AvailableOrganizerIdTypes}"
                               SelectedItem="{Binding OrganizerIdType}"
                               HorizontalAlignment="Stretch"/>

                    <!-- Passcode row: masked by default. The 'Show' toggle ToggleButton flips
                         PasswordChar to '\0' (rendered empty), unmasking the value in-place.
                         The value itself stays bound to NachPasscode regardless. -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Classes="label" Text="NACH passcode"/>
                    <Grid      Grid.Row="6" Grid.Column="1" ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding NachPasscode}"
                                 PasswordChar="●"
                                 RevealPassword="{Binding ShowNachPasscode}"
                                 Watermark="Secret passcode"/>
                        <ToggleButton Grid.Column="1"
                                      Margin="6,0,0,0"
                                      IsChecked="{Binding ShowNachPasscode, Mode=TwoWay}"
                                      Padding="10,0"
                                      ToolTip.Tip="Show / hide the passcode">
                            <TextBlock Text="👁" FontSize="14"/>
                        </ToggleButton>
                    </Grid>

                    <TextBlock Grid.Row="7" Grid.Column="0" Classes="label" Text="NACH event ID"/>
                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding NachEventId}" VerticalAlignment="Center" Foreground="Gray" FontFamily="Consolas,monospace" FontSize="11"/>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Discard changes" Command="{Binding DiscardCommand}" MinWidth="140"/>
                <Button Content="Apply" Command="{Binding ApplyCommand}" IsDefault="True" MinWidth="100" Background="#0E5DAA" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
