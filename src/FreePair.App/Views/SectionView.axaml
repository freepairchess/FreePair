<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FreePair.App.ViewModels"
             xmlns:standings="using:FreePair.Core.Tournaments.Standings"
             xmlns:wc="using:FreePair.Core.Tournaments.WallCharts"
             xmlns:core="using:FreePair.Core.Tournaments"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="FreePair.App.Views.SectionView"
             x:DataType="vm:SectionViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.colHeader">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="DimGray"/>
        </Style>
        <Style Selector="TextBlock.cell">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.row">
            <Setter Property="BorderBrush" Value="#EEEEEE"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style Selector="TextBlock.mono">
            <Setter Property="FontFamily" Value="Consolas, Menlo, monospace"/>
        </Style>
    </UserControl.Styles>

    <DockPanel LastChildFill="True">

        <!-- Section header -->
        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,10">
            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Foreground="Gray" FontSize="12">
                <Run Text="{Binding PlayerCount}"/>
                <Run Text=" players · "/>
                <Run Text="{Binding RoundsPlayed}"/>
                <Run Text=" of "/>
                <Run Text="{Binding RoundsPaired}"/>
                <Run Text=" rounds"/>
            </TextBlock>
        </StackPanel>

        <!-- Soft-deleted banner. Visible only when the section has
             IsSoftDeleted=true. Offers Undelete (reversible) and
             Permanently delete (with scary confirm). Every downstream
             control on the Pairings tab is disabled by binding to
             IsLive via CanPairNextRound / CanDeleteLastRound, and the
             domain mutations refuse soft-deleted sections too. -->
        <Border DockPanel.Dock="Top"
                Margin="0,0,0,10"
                Padding="12,8"
                CornerRadius="4"
                Background="#FFF8E1"
                BorderBrush="#F6C66C"
                BorderThickness="1"
                IsVisible="{Binding IsSoftDeleted}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
                    <Button Content="Undelete"
                            Command="{Binding UndeleteSectionCommand}"
                            ToolTip.Tip="Restore this section. All data is intact; mutations and publishing resume normally."/>
                    <Button Content="Permanently delete…"
                            Command="{Binding HardDeleteSectionCommand}"
                            Foreground="DarkRed"
                            ToolTip.Tip="Discard this section forever. All players, rounds, pairings, and results are lost; cannot be undone short of restoring a backup."/>
                </StackPanel>
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" Text="This section is soft-deleted."/>
                    <TextBlock Foreground="#6A5200" FontSize="12"
                               Text="No further edits are allowed, and it will not appear in published NA Chess Hub results. All data is preserved — click Undelete to restore it."
                               TextWrapping="Wrap"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

            <!-- =============== Overview =============== -->
            <TabItem Header="Overview">
                <StackPanel Spacing="8" Margin="8">
                    <TextBlock FontWeight="SemiBold" Text="Section summary"/>
                    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Foreground="Gray"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Time control" Foreground="Gray"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TimeControl}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Players" Foreground="Gray"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PlayerCount}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Rounds paired" Foreground="Gray"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RoundsPaired}"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Rounds played" Foreground="Gray"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RoundsPlayed}"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Teams" Foreground="Gray"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding TeamCount}"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Requested byes" Foreground="Gray"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding RequestedByeCount}"/>
                    </Grid>

                    <!-- Section-level danger zone. Only the soft-delete
                         entry point lives here; Undelete / Permanently
                         delete… surface in the yellow banner at the top
                         of the section view once the section is
                         soft-deleted. Hidden when the section is already
                         soft-deleted so the two affordances don't
                         duplicate each other. -->
                    <Border Margin="0,16,0,0"
                            Padding="12,8"
                            CornerRadius="4"
                            BorderBrush="#E0D0D0"
                            BorderThickness="1"
                            IsVisible="{Binding IsLive}">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Content="🗑 Delete section…"
                                    Command="{Binding SoftDeleteSectionCommand}"
                                    Foreground="DarkRed"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Soft-delete this section. Locks it against edits and excludes it from published results. Reversible via the Undelete button that appears afterwards."/>
                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Danger zone" FontWeight="SemiBold" Foreground="DarkRed"/>
                                <TextBlock Foreground="Gray" FontSize="11" TextWrapping="Wrap"
                                           Text="Soft-delete locks the section against edits and hides it from published results. Data is preserved and can be restored. Permanent deletion is available afterwards from the yellow banner."/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <!-- =============== Players =============== -->
            <TabItem Header="Players">
                <DockPanel LastChildFill="True" Margin="8">

                    <!-- Filter bar -->
                    <Border DockPanel.Dock="Top"
                            Background="#F6F6F6"
                            BorderBrush="LightGray"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8"
                            Margin="0,0,0,8">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="Filter:"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding PlayerFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Watermark="Search by name, ID, club, state, team, email, phone, or pair #"
                                     MinWidth="280"/>
                            <Button Grid.Column="2"
                                    Content="Clear"
                                    Click="OnClearPlayerFilter"
                                    Margin="8,0,0,0"
                                    IsVisible="{Binding PlayerFilter, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <TextBlock Grid.Column="3"
                                       Text="{Binding FilteredPlayerCountText}"
                                       VerticalAlignment="Center"
                                       Foreground="Gray"
                                       FontSize="11"
                                       Margin="12,0,0,0"/>
                            <Button Grid.Column="4"
                                    Content="📄 Print as PDF"
                                    Click="OnPrintPlayersPdf"
                                    Margin="12,0,0,0"
                                    ToolTip.Tip="Export the Players list as a PDF."/>
                        </Grid>
                    </Border>

                    <!-- Sortable, resizable grid. Column sorting is built into the DataGrid;
                         SortMemberPath identifies the underlying value used (so e.g. Rating
                         sorts numerically rather than as text). -->
                    <DataGrid ItemsSource="{Binding FilteredPlayers}"
                              CanUserSortColumns="True"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="True"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              AutoGenerateColumns="False"
                              HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Pair"
                                                Binding="{Binding PairNumber}"
                                                SortMemberPath="PairNumber"
                                                Width="60"/>

                            <!-- USCF id: value + copy button (shown only when the id is set). -->
                            <DataGridTemplateColumn Header="USCF" SortMemberPath="UscfId" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="vm:PlayerRow">
                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding UscfId}"
                                                       Foreground="Gray"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       Padding="8,0,0,0"/>
                                            <Button Grid.Column="1"
                                                    Content="⧉"
                                                    Tag="{Binding UscfId}"
                                                    Click="OnCopyFieldClick"
                                                    Padding="4,0" MinHeight="20" FontSize="11"
                                                    Background="Transparent" BorderThickness="0"
                                                    IsVisible="{Binding UscfId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    ToolTip.Tip="Copy USCF id to clipboard"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Name: value + copy button (always present). -->
                            <DataGridTemplateColumn Header="Name" SortMemberPath="Name" Width="*" MinWidth="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="vm:PlayerRow">
                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding Name}"
                                                       VerticalAlignment="Center"
                                                       Padding="8,0,0,0"/>
                                            <Button Grid.Column="1"
                                                    Content="⧉"
                                                    Tag="{Binding Name}"
                                                    Click="OnCopyFieldClick"
                                                    Padding="4,0" MinHeight="20" FontSize="11"
                                                    Background="Transparent" BorderThickness="0"
                                                    IsVisible="{Binding Name, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    ToolTip.Tip="Copy name to clipboard"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Rating: value + copy (always shown; numeric Tag coerced via ToString in the handler). -->
                            <DataGridTemplateColumn Header="Rating" SortMemberPath="Rating" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="vm:PlayerRow">
                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Rating}"
                                                       VerticalAlignment="Center"
                                                       Padding="8,0,0,0"/>
                                            <Button Grid.Column="1"
                                                    Content="⧉"
                                                    Tag="{Binding Rating}"
                                                    Click="OnCopyFieldClick"
                                                    Padding="4,0" MinHeight="20" FontSize="11"
                                                    Background="Transparent" BorderThickness="0"
                                                    ToolTip.Tip="Copy rating to clipboard"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Club"
                                                Binding="{Binding Club}"
                                                SortMemberPath="Club"
                                                Width="80"/>
                            <DataGridTextColumn Header="State"
                                                Binding="{Binding State}"
                                                SortMemberPath="State"
                                                Width="60"/>

                            <!-- Team: value + copy button (shown only when team name is set). -->
                            <DataGridTemplateColumn Header="Team" SortMemberPath="Team" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="vm:PlayerRow">
                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Team}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding Team}"
                                                       VerticalAlignment="Center"
                                                       Padding="8,0,0,0"/>
                                            <Button Grid.Column="1"
                                                    Content="⧉"
                                                    Tag="{Binding Team}"
                                                    Click="OnCopyFieldClick"
                                                    Padding="4,0" MinHeight="20" FontSize="11"
                                                    Background="Transparent" BorderThickness="0"
                                                    IsVisible="{Binding Team, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    ToolTip.Tip="Copy team to clipboard"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Email: value + inline copy button. Template column so we can
                                 embed a Button; sort-member points at the plain string so
                                 the sort indicator still works. -->
                            <DataGridTemplateColumn Header="Email" SortMemberPath="Email" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="vm:PlayerRow">
                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Email}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding Email}"
                                                       VerticalAlignment="Center"
                                                       Padding="8,0,0,0"/>
                                            <Button Grid.Column="1"
                                                    Content="⧉"
                                                    Tag="{Binding Email}"
                                                    Click="OnCopyFieldClick"
                                                    Padding="4,0"
                                                    MinHeight="20"
                                                    FontSize="11"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    IsVisible="{Binding Email, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    ToolTip.Tip="Copy email to clipboard"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Phone: same pattern as Email. -->
                            <DataGridTemplateColumn Header="Phone" SortMemberPath="Phone" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="vm:PlayerRow">
                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Phone}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip.Tip="{Binding Phone}"
                                                       VerticalAlignment="Center"
                                                       Padding="8,0,0,0"/>
                                            <Button Grid.Column="1"
                                                    Content="⧉"
                                                    Tag="{Binding Phone}"
                                                    Click="OnCopyFieldClick"
                                                    Padding="4,0"
                                                    MinHeight="20"
                                                    FontSize="11"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    IsVisible="{Binding Phone, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    ToolTip.Tip="Copy phone to clipboard"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Sort by the numeric Score (not the pre-formatted text) so
                                 "½" sorts between 0 and 1 correctly. -->
                            <DataGridTextColumn Header="Score"
                                                Binding="{Binding ScoreText}"
                                                SortMemberPath="Score"
                                                Width="70"/>
                            <!-- Player-requested byes, split into two
                                 columns so the TD can spot each kind
                                 at a glance. These are TD-granted
                                 per-round requests (SwissSys "Reserved
                                 byes" + FreePair "zero-point bye rounds")
                                 — not the full-point byes BBP hands out
                                 when a section has an odd count. Values
                                 are comma-separated round numbers; empty
                                 cell means no request of that kind. -->
                            <DataGridTextColumn Header="½-pt byes"
                                                Binding="{Binding HalfByeRounds}"
                                                SortMemberPath="HalfByeRounds"
                                                Width="90"/>
                            <DataGridTextColumn Header="0-pt byes"
                                                Binding="{Binding ZeroByeRounds}"
                                                SortMemberPath="ZeroByeRounds"
                                                Width="90"/>
                            <DataGridTextColumn Header="Status"
                                                Binding="{Binding Status}"
                                                SortMemberPath="Status"
                                                Width="100"/>

                            <!-- Player lifecycle actions. Five icons:
                                 green 🗑 soft-delete, blue ↩ undelete,
                                 red 🗑 hard-delete (all pre-round-1),
                                 orange ⊘ withdraw, blue ↩ return from
                                 withdrawal (both post-round-1). Visibility
                                 bound to PlayerRow flags derived from
                                 the player's SoftDeleted/Withdrawn state
                                 and the section's RoundsPaired, so
                                 exactly one set of icons applies. -->
                            <DataGridTemplateColumn Header="" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="vm:PlayerRow">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left">
                                            <Button Classes="icon-btn"
                                                    Foreground="SeaGreen"
                                                    Content="&#xE74D;"
                                                    Tag="{Binding PairNumber}"
                                                    Click="OnPlayerSoftDeleteClick"
                                                    IsVisible="{Binding CanSoftDelete}"
                                                    ToolTip.Tip="Soft-delete player (reversible). Only allowed before round 1 is paired."/>
                                            <Button Classes="icon-btn"
                                                    Foreground="#0E5DAA"
                                                    Content="&#xE7A7;"
                                                    Tag="{Binding PairNumber}"
                                                    Click="OnPlayerUndeleteClick"
                                                    IsVisible="{Binding CanUndelete}"
                                                    ToolTip.Tip="Restore this soft-deleted player."/>
                                            <Button Classes="icon-btn"
                                                    Foreground="#C62828"
                                                    Content="&#xE74D;"
                                                    Tag="{Binding PairNumber}"
                                                    Click="OnPlayerHardDeleteClick"
                                                    IsVisible="{Binding CanHardDelete}"
                                                    ToolTip.Tip="Permanently delete this player."/>
                                            <Button Classes="icon-btn"
                                                    Foreground="#D68100"
                                                    Content="&#xE711;"
                                                    Tag="{Binding PairNumber}"
                                                    Click="OnPlayerWithdrawClick"
                                                    IsVisible="{Binding CanWithdraw}"
                                                    ToolTip.Tip="Withdraw player from future pairing. Past results stay in place; you can return them later."/>
                                            <Button Classes="icon-btn"
                                                    Foreground="#0E5DAA"
                                                    Content="&#xE7A7;"
                                                    Tag="{Binding PairNumber}"
                                                    Click="OnPlayerUnwithdrawClick"
                                                    IsVisible="{Binding CanUnwithdraw}"
                                                    ToolTip.Tip="Return this withdrawn player to the active roster."/>
                                            <!-- Manage requested byes. Visible
                                                 for live, non-withdrawn players
                                                 when at least one unpaired
                                                 future round exists. Opens a
                                                 modal dialog with a row per
                                                 round and None / ½-pt / 0-pt
                                                 choices. -->
                                            <Button Classes="icon-btn"
                                                    Foreground="#5A5A5A"
                                                    Content="&#xE70F;"
                                                    Tag="{Binding PairNumber}"
                                                    Click="OnPlayerManageByesClick"
                                                    IsVisible="{Binding CanManageByes}"
                                                    ToolTip.Tip="Manage requested byes for this player's future unpaired rounds."/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- =============== Pairings =============== -->
            <TabItem Header="Pairings">
                <DockPanel LastChildFill="True" Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <TextBlock Text="Round:" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding AvailableRounds}"
                                  SelectedItem="{Binding SelectedRound}"
                                  MinWidth="140"/>
                        <Button Content="Pair next round"
                                Command="{Binding PairNextRoundCommand}"
                                IsEnabled="{Binding CanPairNextRound}"
                                ToolTip.Tip="Generate the next round's pairings via BBP. Requires the pairing engine to be configured in Settings."/>
                        <Button Content="{Binding DeleteLastRoundLabel}"
                                Command="{Binding DeleteLastRoundCommand}"
                                IsEnabled="{Binding CanDeleteLastRound}"
                                Foreground="DarkRed"
                                ToolTip.Tip="Remove the most recent round's pairings and results. Useful for fixing mistakes; cannot be undone."/>
                        <Button Content="📄 Print as PDF"
                                Click="OnPrintPairingsPdf"
                                IsEnabled="{Binding HasSelectedRound}"
                                ToolTip.Tip="Export the selected round's pairings as a PDF."/>
                        <TextBlock Text="{Binding PairNextRoundBlockReason}"
                                   Foreground="DimGray"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding PairNextRoundBlockReason, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        <TextBlock Text="Pairing..."
                                   Foreground="DarkBlue"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsPairingNextRound}"/>
                    </StackPanel>

                    <ScrollViewer>
                        <StackPanel Spacing="12">

                            <!-- Filter bar for the Pairings DataGrid. -->
                            <Border Background="#F6F6F6"
                                    BorderBrush="LightGray"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <TextBlock Grid.Column="0" Text="Filter:"
                                               VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding PairingFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Watermark="Search by board, pair #, or player name"
                                             MinWidth="260"/>
                                    <Button Grid.Column="2"
                                            Content="Clear"
                                            Click="OnClearPairingFilter"
                                            Margin="8,0,0,0"
                                            IsVisible="{Binding PairingFilter, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </Grid>
                            </Border>

                            <!-- Sortable / resizable pairings grid. Result is a template-column ComboBox
                                 so the TD can still enter a result directly; SortMemberPath points at
                                 the text version so sort order makes sense. When the section is
                                 soft-deleted the whole grid is disabled so the Result ComboBoxes
                                 can't fire mutations (which would throw at the domain layer anyway). -->
                            <DataGrid ItemsSource="{Binding FilteredPairings}"
                                      CanUserSortColumns="True"
                                      CanUserResizeColumns="True"
                                      CanUserReorderColumns="True"
                                      IsReadOnly="False"
                                      IsEnabled="{Binding IsLive}"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      SelectionMode="Single"
                                      AutoGenerateColumns="False"
                                      HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Bd"       Binding="{Binding Board}"       SortMemberPath="Board"       Width="50"  IsReadOnly="True"/>
                                    <DataGridTextColumn Header="White #"  Binding="{Binding WhitePair}"   SortMemberPath="WhitePair"   Width="70"  IsReadOnly="True"/>
                                    <DataGridTextColumn Header="White"    Binding="{Binding WhiteName}"   SortMemberPath="WhiteName"   Width="*"   MinWidth="140" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Rtg"      Binding="{Binding WhiteRating}" SortMemberPath="WhiteRating" Width="70"  IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Black #"  Binding="{Binding BlackPair}"   SortMemberPath="BlackPair"   Width="70"  IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Black"    Binding="{Binding BlackName}"   SortMemberPath="BlackName"   Width="*"   MinWidth="140" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="Rtg"      Binding="{Binding BlackRating}" SortMemberPath="BlackRating" Width="70"  IsReadOnly="True"/>
                                    <!-- Result column: a ComboBox in the
                                         default cell template so one click
                                         drops it open. We previously kept
                                         the ComboBox in CellEditingTemplate
                                         to dodge an Avalonia 12 popup-attach
                                         NRE, but that forced the TD to
                                         double-click / F2 which turned out
                                         to be too discoverable-poor. If the
                                         NRE re-surfaces we'll handle it at
                                         the VM rebuild path instead. -->
                                    <DataGridTemplateColumn Header="Result" SortMemberPath="ResultText" Width="140" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate DataType="vm:PairingRow">
                                                <ComboBox ItemsSource="{Binding AvailableResults}"
                                                          SelectedItem="{Binding SelectedResult, Mode=TwoWay}"
                                                          Margin="4,2" MinWidth="120"
                                                          VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel IsVisible="{Binding CurrentRoundByes.Count}" Spacing="4">
                                <TextBlock Text="Byes this round" FontWeight="SemiBold" Foreground="DimGray"/>
                                <ItemsControl ItemsSource="{Binding CurrentRoundByes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:ByeRow">
                                            <Border Classes="row">
                                                <Grid ColumnDefinitions="60,*,140">
                                                    <TextBlock Grid.Column="0" Classes="cell" Text="{Binding PairNumber}"/>
                                                    <TextBlock Grid.Column="1" Classes="cell" Text="{Binding Name}"/>
                                                    <TextBlock Grid.Column="2" Classes="cell" Text="{Binding Kind}" Foreground="DarkBlue"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- =============== Standings =============== -->
            <TabItem Header="Standings">
                <DockPanel LastChildFill="True" Margin="8">
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Spacing="8"
                                Margin="0,0,0,8">
                        <Button Content="📄 Print as PDF"
                                Click="OnPrintStandingsPdf"
                                ToolTip.Tip="Export the current standings as a PDF."/>
                    </StackPanel>

                    <Border DockPanel.Dock="Top"
                            Background="#F6F6F6"
                            BorderBrush="LightGray"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8"
                            Margin="0,0,0,8">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="Filter:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding StandingsFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Watermark="Search by name, pair #, place, or rating"
                                     MinWidth="260"/>
                            <Button Grid.Column="2" Content="Clear" Click="OnClearStandingsFilter"
                                    Margin="8,0,0,0"
                                    IsVisible="{Binding StandingsFilter, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </Grid>
                    </Border>

                    <DataGrid ItemsSource="{Binding FilteredStandings}"
                              CanUserSortColumns="True"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="True"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              AutoGenerateColumns="False"
                              HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Place"   Binding="{Binding Row.Place}"       SortMemberPath="Row.Rank"   Width="70"/>
                            <DataGridTextColumn Header="Pair"    Binding="{Binding Row.PairNumber}"  SortMemberPath="Row.PairNumber" Width="60"/>
                            <DataGridTextColumn Header="Name"    Binding="{Binding Row.Name}"        SortMemberPath="Row.Name"   Width="*" MinWidth="160"/>
                            <DataGridTextColumn Header="Rating"  Binding="{Binding Row.Rating}"      SortMemberPath="Row.Rating" Width="70"/>
                            <DataGridTextColumn Header="Score"   Binding="{Binding ScoreText}"       SortMemberPath="Row.Score"  Width="70"/>
                            <DataGridTextColumn Header="Mod.Med" Binding="{Binding ModMedText}"      SortMemberPath="Row.Tiebreaks.ModifiedMedian"     Width="80"/>
                            <DataGridTextColumn Header="Solk"    Binding="{Binding SolkoffText}"     SortMemberPath="Row.Tiebreaks.Solkoff"            Width="80"/>
                            <DataGridTextColumn Header="Cumul"   Binding="{Binding CumulativeText}"  SortMemberPath="Row.Tiebreaks.Cumulative"         Width="80"/>
                            <DataGridTextColumn Header="Op.Cumul" Binding="{Binding OppCumulativeText}" SortMemberPath="Row.Tiebreaks.OpponentCumulative" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- =============== Wall Chart =============== -->
            <TabItem Header="Wall Chart">
                <DockPanel LastChildFill="True" Margin="8">
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Spacing="8"
                                Margin="0,0,0,8">
                        <Button Content="📄 Print as PDF"
                                Click="OnPrintWallChartPdf"
                                ToolTip.Tip="Export the wall chart as a PDF (landscape orientation)."/>
                    </StackPanel>

                    <Border DockPanel.Dock="Top"
                            Background="#F6F6F6"
                            BorderBrush="LightGray"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8"
                            Margin="0,0,0,8">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="Filter:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding WallChartFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Watermark="Search by name, pair #, club, state, or team"
                                     MinWidth="260"/>
                            <Button Grid.Column="2" Content="Clear" Click="OnClearWallChartFilter"
                                    Margin="8,0,0,0"
                                    IsVisible="{Binding WallChartFilter, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </Grid>
                    </Border>

                    <!-- Wall-chart DataGrid keeps the inline round-code cells as a template column
                         so the per-round glyphs still render; the rest of the columns gain sort +
                         resize + reorder like every other tab. -->
                    <DataGrid ItemsSource="{Binding FilteredWallChart}"
                              CanUserSortColumns="True"
                              CanUserResizeColumns="True"
                              CanUserReorderColumns="True"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              AutoGenerateColumns="False"
                              HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Pair"   Binding="{Binding Row.PairNumber}" SortMemberPath="Row.PairNumber" Width="60"/>
                            <DataGridTextColumn Header="Name"   Binding="{Binding Row.Name}"       SortMemberPath="Row.Name"       Width="*" MinWidth="160"/>
                            <DataGridTextColumn Header="Rating" Binding="{Binding Row.Rating}"     SortMemberPath="Row.Rating"     Width="70"/>
                            <DataGridTemplateColumn Header="Rounds" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="vm:WallChartDisplayRow">
                                        <ItemsControl ItemsSource="{Binding Row.Cells}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="wc:WallChartCell">
                                                    <Border MinWidth="56" Padding="4,3"
                                                            BorderBrush="#EEEEEE"
                                                            BorderThickness="1,0,0,0">
                                                        <TextBlock Classes="mono"
                                                                   Text="{Binding Code}"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Score"    Binding="{Binding ScoreText}"       SortMemberPath="Row.Score" Width="70"/>
                            <DataGridTextColumn Header="Mod.Med"  Binding="{Binding ModMedText}"      SortMemberPath="Row.Tiebreaks.ModifiedMedian" Width="80"/>
                            <DataGridTextColumn Header="Solk"     Binding="{Binding SolkoffText}"     SortMemberPath="Row.Tiebreaks.Solkoff" Width="80"/>
                            <DataGridTextColumn Header="Cumul"    Binding="{Binding CumulativeText}"  SortMemberPath="Row.Tiebreaks.Cumulative" Width="80"/>
                            <DataGridTextColumn Header="Op.Cumul" Binding="{Binding OppCumulativeText}" SortMemberPath="Row.Tiebreaks.OpponentCumulative" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- =============== Prizes =============== -->
            <TabItem Header="Prizes">
                <DockPanel LastChildFill="True" Margin="8">
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Spacing="8"
                                Margin="0,0,0,8">
                        <Button Content="📄 Print as PDF"
                                Click="OnPrintPrizesPdf"
                                ToolTip.Tip="Export the prize-fund summary as a PDF."/>
                    </StackPanel>
                    <ScrollViewer>
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Place prizes" FontWeight="SemiBold"/>
                            <TextBlock Text="None declared."
                                       Foreground="Gray"
                                       IsVisible="{Binding !Section.Prizes.Place.Count}"/>
                            <ItemsControl ItemsSource="{Binding Section.Prizes.Place}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="core:Prize">
                                        <Border Classes="row">
                                            <Grid ColumnDefinitions="90,*">
                                                <TextBlock Grid.Column="0" Classes="cell" Text="{Binding Value, StringFormat=\{0:C\}}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Classes="cell" Text="{Binding Description}" Foreground="Gray"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Class prizes" FontWeight="SemiBold"/>
                            <TextBlock Text="None declared."
                                       Foreground="Gray"
                                       IsVisible="{Binding !Section.Prizes.Class.Count}"/>
                            <ItemsControl ItemsSource="{Binding Section.Prizes.Class}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="core:Prize">
                                        <Border Classes="row">
                                            <Grid ColumnDefinitions="90,*">
                                                <TextBlock Grid.Column="0" Classes="cell" Text="{Binding Value, StringFormat=\{0:C\}}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Classes="cell" Text="{Binding Description}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- =============== Byes & Withdrawals =============== -->
            <TabItem Header="Byes &amp; Withdrawals">
                <DockPanel LastChildFill="True" Margin="8">

                    <Border DockPanel.Dock="Top"
                            Background="#F6F6F6"
                            BorderBrush="LightGray"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8"
                            Margin="0,0,0,8">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="Filter:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding ByesFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Watermark="Search by round, pair #, name, or kind (Full / Half)"
                                     MinWidth="260"/>
                            <Button Grid.Column="2" Content="Clear" Click="OnClearByesFilter"
                                    Margin="8,0,0,0"
                                    IsVisible="{Binding ByesFilter, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </Grid>
                    </Border>

                    <ScrollViewer>
                        <StackPanel Spacing="16">

                            <StackPanel Spacing="4">
                                <TextBlock Text="All byes and unpaired rounds" FontWeight="SemiBold"/>
                                <TextBlock Text="None recorded."
                                           Foreground="Gray"
                                           IsVisible="{Binding !AllByes.Count}"/>
                                <DataGrid ItemsSource="{Binding FilteredAllByes}"
                                          CanUserSortColumns="True"
                                          CanUserResizeColumns="True"
                                          CanUserReorderColumns="True"
                                          IsReadOnly="True"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          SelectionMode="Single"
                                          AutoGenerateColumns="False"
                                          HorizontalScrollBarVisibility="Auto"
                                          MaxHeight="380">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Round" Binding="{Binding Round}"      SortMemberPath="Round"      Width="70"/>
                                        <DataGridTextColumn Header="Pair"  Binding="{Binding PairNumber}" SortMemberPath="PairNumber" Width="70"/>
                                        <DataGridTextColumn Header="Name"  Binding="{Binding Name}"       SortMemberPath="Name"       Width="*" MinWidth="160"/>
                                        <DataGridTextColumn Header="Kind"  Binding="{Binding Kind}"       SortMemberPath="Kind"       Width="140"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Players with requested (future) byes" FontWeight="SemiBold"/>
                                <!-- Split row: ½-pt rounds shown in
                                     dark blue, 0-pt rounds in dark red
                                     so the two kinds can be spotted
                                     at a glance. Row hides if the
                                     player has neither. -->
                                <ItemsControl ItemsSource="{Binding Players}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:PlayerRow">
                                            <Border Classes="row"
                                                    IsVisible="{Binding RequestedByes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                <Grid ColumnDefinitions="60,*,Auto,Auto">
                                                    <TextBlock Grid.Column="0" Classes="cell" Text="{Binding PairNumber}"/>
                                                    <TextBlock Grid.Column="1" Classes="cell" Text="{Binding Name}"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                                                Margin="0,0,16,0"
                                                                IsVisible="{Binding HalfByeRounds, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                        <TextBlock Classes="cell" Text="½-pt:" Foreground="Gray" FontSize="11"/>
                                                        <TextBlock Classes="cell" Text="{Binding HalfByeRounds}" Foreground="DarkBlue"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4"
                                                                IsVisible="{Binding ZeroByeRounds, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                        <TextBlock Classes="cell" Text="0-pt:" Foreground="Gray" FontSize="11"/>
                                                        <TextBlock Classes="cell" Text="{Binding ZeroByeRounds}" Foreground="DarkRed"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>

</UserControl>
