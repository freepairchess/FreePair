<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FreePair.App.ViewModels"
             xmlns:standings="using:FreePair.Core.Tournaments.Standings"
             xmlns:wc="using:FreePair.Core.Tournaments.WallCharts"
             xmlns:core="using:FreePair.Core.Tournaments"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
             x:Class="FreePair.App.Views.SectionView"
             x:DataType="vm:SectionViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.colHeader">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="DimGray"/>
        </Style>
        <Style Selector="TextBlock.cell">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.row">
            <Setter Property="BorderBrush" Value="#EEEEEE"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style Selector="TextBlock.mono">
            <Setter Property="FontFamily" Value="Consolas, Menlo, monospace"/>
        </Style>
    </UserControl.Styles>

    <DockPanel LastChildFill="True">

        <!-- Section header -->
        <StackPanel DockPanel.Dock="Top" Spacing="2" Margin="0,0,0,10">
            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Foreground="Gray" FontSize="12">
                <Run Text="{Binding PlayerCount}"/>
                <Run Text=" players · "/>
                <Run Text="{Binding RoundsPlayed}"/>
                <Run Text=" of "/>
                <Run Text="{Binding RoundsPaired}"/>
                <Run Text=" rounds"/>
            </TextBlock>
        </StackPanel>

        <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

            <!-- =============== Overview =============== -->
            <TabItem Header="Overview">
                <StackPanel Spacing="8" Margin="8">
                    <TextBlock FontWeight="SemiBold" Text="Section summary"/>
                    <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Foreground="Gray"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Name}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Time control" Foreground="Gray"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TimeControl}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Players" Foreground="Gray"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PlayerCount}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Rounds paired" Foreground="Gray"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RoundsPaired}"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Rounds played" Foreground="Gray"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RoundsPlayed}"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Teams" Foreground="Gray"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding TeamCount}"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Requested byes" Foreground="Gray"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding RequestedByeCount}"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- =============== Players =============== -->
            <TabItem Header="Players">
                <DockPanel LastChildFill="True" Margin="8">
                    <Grid DockPanel.Dock="Top"
                          ColumnDefinitions="50,70,*,80,60,60,100,170,130,70,100"
                          Margin="0,0,0,4">
                        <TextBlock Grid.Column="0"  Classes="colHeader" Text="Pair"/>
                        <TextBlock Grid.Column="1"  Classes="colHeader" Text="USCF"/>
                        <TextBlock Grid.Column="2"  Classes="colHeader" Text="Name"/>
                        <TextBlock Grid.Column="3"  Classes="colHeader" Text="Rating"/>
                        <TextBlock Grid.Column="4"  Classes="colHeader" Text="Club"/>
                        <TextBlock Grid.Column="5"  Classes="colHeader" Text="State"/>
                        <TextBlock Grid.Column="6"  Classes="colHeader" Text="Team"/>
                        <TextBlock Grid.Column="7"  Classes="colHeader" Text="Email"/>
                        <TextBlock Grid.Column="8"  Classes="colHeader" Text="Phone"/>
                        <TextBlock Grid.Column="9"  Classes="colHeader" Text="Score" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="10" Classes="colHeader" Text="Status"/>
                    </Grid>
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Players}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:PlayerRow">
                                    <Border Classes="row">
                                        <Grid ColumnDefinitions="50,70,*,80,60,60,100,170,130,70,100">
                                            <TextBlock Grid.Column="0" Classes="cell" Text="{Binding PairNumber}"/>
                                            <TextBlock Grid.Column="1" Classes="cell" Text="{Binding UscfId}" Foreground="Gray"/>
                                            <TextBlock Grid.Column="2" Classes="cell" Text="{Binding Name}"/>
                                            <TextBlock Grid.Column="3" Classes="cell" Text="{Binding Rating}"/>
                                            <TextBlock Grid.Column="4" Classes="cell" Text="{Binding Club}"/>
                                            <TextBlock Grid.Column="5" Classes="cell" Text="{Binding State}"/>
                                            <TextBlock Grid.Column="6" Classes="cell" Text="{Binding Team}"/>

                                            <!-- Email cell with copy button -->
                                            <Grid Grid.Column="7" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                                <TextBlock Grid.Column="0"
                                                           Classes="cell"
                                                           Text="{Binding Email}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding Email}"/>
                                                <Button Grid.Column="1"
                                                        Content="⧉"
                                                        Tag="{Binding Email}"
                                                        Click="OnCopyFieldClick"
                                                        Padding="4,0"
                                                        MinHeight="20"
                                                        FontSize="11"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        IsVisible="{Binding Email, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                        ToolTip.Tip="Copy email to clipboard"/>
                                            </Grid>

                                            <!-- Phone cell with copy button -->
                                            <Grid Grid.Column="8" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                                <TextBlock Grid.Column="0"
                                                           Classes="cell"
                                                           Text="{Binding Phone}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding Phone}"/>
                                                <Button Grid.Column="1"
                                                        Content="⧉"
                                                        Tag="{Binding Phone}"
                                                        Click="OnCopyFieldClick"
                                                        Padding="4,0"
                                                        MinHeight="20"
                                                        FontSize="11"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        IsVisible="{Binding Phone, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                        ToolTip.Tip="Copy phone to clipboard"/>
                                            </Grid>

                                            <TextBlock Grid.Column="9"  Classes="cell" Text="{Binding ScoreText}" HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="10" Classes="cell" Text="{Binding Status}" Foreground="DarkBlue"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- =============== Pairings =============== -->
            <TabItem Header="Pairings">
                <DockPanel LastChildFill="True" Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <TextBlock Text="Round:" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding AvailableRounds}"
                                  SelectedItem="{Binding SelectedRound}"
                                  MinWidth="140"/>
                        <Button Content="Pair next round"
                                Command="{Binding PairNextRoundCommand}"
                                IsEnabled="{Binding CanPairNextRound}"
                                ToolTip.Tip="Generate the next round's pairings via BBP. Requires the pairing engine to be configured in Settings."/>
                        <Button Content="{Binding DeleteLastRoundLabel}"
                                Command="{Binding DeleteLastRoundCommand}"
                                IsEnabled="{Binding CanDeleteLastRound}"
                                Foreground="DarkRed"
                                ToolTip.Tip="Remove the most recent round's pairings and results. Useful for fixing mistakes; cannot be undone."/>
                        <TextBlock Text="{Binding PairNextRoundBlockReason}"
                                   Foreground="DimGray"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding PairNextRoundBlockReason, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        <TextBlock Text="Pairing..."
                                   Foreground="DarkBlue"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsPairingNextRound}"/>
                    </StackPanel>

                    <ScrollViewer>
                        <StackPanel Spacing="12">

                            <StackPanel Spacing="0">
                                <Grid ColumnDefinitions="50,50,*,60,60,*,50,120"
                                      Margin="0,0,0,4">
                                    <TextBlock Grid.Column="0" Classes="colHeader" Text="Bd"/>
                                    <TextBlock Grid.Column="1" Classes="colHeader" Text="White#"/>
                                    <TextBlock Grid.Column="2" Classes="colHeader" Text="White"/>
                                    <TextBlock Grid.Column="3" Classes="colHeader" Text="Rtg"/>
                                    <TextBlock Grid.Column="4" Classes="colHeader" Text="Black#"/>
                                    <TextBlock Grid.Column="5" Classes="colHeader" Text="Black"/>
                                    <TextBlock Grid.Column="6" Classes="colHeader" Text="Rtg"/>
                                    <TextBlock Grid.Column="7" Classes="colHeader" Text="Result"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding CurrentRoundPairings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:PairingRow">
                                            <Border Classes="row">
                                                <Grid ColumnDefinitions="50,50,*,60,60,*,50,120">
                                                    <TextBlock Grid.Column="0" Classes="cell" Text="{Binding Board}"/>
                                                    <TextBlock Grid.Column="1" Classes="cell" Text="{Binding WhitePair}"/>
                                                    <TextBlock Grid.Column="2" Classes="cell" Text="{Binding WhiteName}"/>
                                                    <TextBlock Grid.Column="3" Classes="cell" Text="{Binding WhiteRating}"/>
                                                    <TextBlock Grid.Column="4" Classes="cell" Text="{Binding BlackPair}"/>
                                                    <TextBlock Grid.Column="5" Classes="cell" Text="{Binding BlackName}"/>
                                                    <TextBlock Grid.Column="6" Classes="cell" Text="{Binding BlackRating}"/>
                                                    <ComboBox Grid.Column="7"
                                                              ItemsSource="{Binding AvailableResults}"
                                                              SelectedItem="{Binding SelectedResult}"
                                                              MinWidth="100"
                                                              Margin="4,2"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel IsVisible="{Binding CurrentRoundByes.Count}" Spacing="4">
                                <TextBlock Text="Byes this round" FontWeight="SemiBold" Foreground="DimGray"/>
                                <ItemsControl ItemsSource="{Binding CurrentRoundByes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:ByeRow">
                                            <Border Classes="row">
                                                <Grid ColumnDefinitions="60,*,140">
                                                    <TextBlock Grid.Column="0" Classes="cell" Text="{Binding PairNumber}"/>
                                                    <TextBlock Grid.Column="1" Classes="cell" Text="{Binding Name}"/>
                                                    <TextBlock Grid.Column="2" Classes="cell" Text="{Binding Kind}" Foreground="DarkBlue"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- =============== Standings =============== -->
            <TabItem Header="Standings">
                <DockPanel LastChildFill="True" Margin="8">
                    <Grid DockPanel.Dock="Top"
                          ColumnDefinitions="60,50,*,70,60,70,70,70,80"
                          Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" Classes="colHeader" Text="Place"/>
                        <TextBlock Grid.Column="1" Classes="colHeader" Text="Pair"/>
                        <TextBlock Grid.Column="2" Classes="colHeader" Text="Name"/>
                        <TextBlock Grid.Column="3" Classes="colHeader" Text="Rating"/>
                        <TextBlock Grid.Column="4" Classes="colHeader" Text="Score" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="5" Classes="colHeader" Text="Mod.Med" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="6" Classes="colHeader" Text="Solk" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="7" Classes="colHeader" Text="Cumul" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="8" Classes="colHeader" Text="Op.Cumul" HorizontalAlignment="Right"/>
                    </Grid>
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding StandingsDisplay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:StandingsDisplayRow">
                                    <Border Classes="row">
                                        <Grid ColumnDefinitions="60,50,*,70,60,70,70,70,80">
                                            <TextBlock Grid.Column="0" Classes="cell" Text="{Binding Row.Place}" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Classes="cell" Text="{Binding Row.PairNumber}"/>
                                            <TextBlock Grid.Column="2" Classes="cell" Text="{Binding Row.Name}"/>
                                            <TextBlock Grid.Column="3" Classes="cell" Text="{Binding Row.Rating}"/>
                                            <TextBlock Grid.Column="4" Classes="cell" Text="{Binding ScoreText}" HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="5" Classes="cell" Text="{Binding ModMedText}" HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="6" Classes="cell" Text="{Binding SolkoffText}" HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="7" Classes="cell" Text="{Binding CumulativeText}" HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="8" Classes="cell" Text="{Binding OppCumulativeText}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- =============== Wall Chart =============== -->
            <TabItem Header="Wall Chart">
                <ScrollViewer Margin="8">
                    <ItemsControl ItemsSource="{Binding WallChart}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="wc:WallChartRow">
                                <Border Classes="row">
                                    <Grid ColumnDefinitions="50,*,70,Auto,70,70,70,70,80" Margin="0,2">
                                        <TextBlock Grid.Column="0" Classes="cell" Text="{Binding PairNumber}"/>
                                        <TextBlock Grid.Column="1" Classes="cell" Text="{Binding Name}"/>
                                        <TextBlock Grid.Column="2" Classes="cell" Text="{Binding Rating}"/>
                                        <ItemsControl Grid.Column="3" ItemsSource="{Binding Cells}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="wc:WallChartCell">
                                                    <Border MinWidth="56"
                                                            Padding="4,3"
                                                            BorderBrush="#EEEEEE"
                                                            BorderThickness="1,0,0,0">
                                                        <TextBlock Classes="mono"
                                                                   Text="{Binding Code}"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Grid.Column="4" Classes="cell" Text="{Binding Score}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="5" Classes="cell" Text="{Binding Tiebreaks.ModifiedMedian}" HorizontalAlignment="Right" Foreground="Gray"/>
                                        <TextBlock Grid.Column="6" Classes="cell" Text="{Binding Tiebreaks.Solkoff}" HorizontalAlignment="Right" Foreground="Gray"/>
                                        <TextBlock Grid.Column="7" Classes="cell" Text="{Binding Tiebreaks.Cumulative}" HorizontalAlignment="Right" Foreground="Gray"/>
                                        <TextBlock Grid.Column="8" Classes="cell" Text="{Binding Tiebreaks.OpponentCumulative}" HorizontalAlignment="Right" Foreground="Gray"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- =============== Prizes =============== -->
            <TabItem Header="Prizes">
                <ScrollViewer Margin="8">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Place prizes" FontWeight="SemiBold"/>
                            <TextBlock Text="None declared."
                                       Foreground="Gray"
                                       IsVisible="{Binding !Section.Prizes.Place.Count}"/>
                            <ItemsControl ItemsSource="{Binding Section.Prizes.Place}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="core:Prize">
                                        <Border Classes="row">
                                            <Grid ColumnDefinitions="90,*">
                                                <TextBlock Grid.Column="0" Classes="cell" Text="{Binding Value, StringFormat=\{0:C\}}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Classes="cell" Text="{Binding Description}" Foreground="Gray"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Class prizes" FontWeight="SemiBold"/>
                            <TextBlock Text="None declared."
                                       Foreground="Gray"
                                       IsVisible="{Binding !Section.Prizes.Class.Count}"/>
                            <ItemsControl ItemsSource="{Binding Section.Prizes.Class}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="core:Prize">
                                        <Border Classes="row">
                                            <Grid ColumnDefinitions="90,*">
                                                <TextBlock Grid.Column="0" Classes="cell" Text="{Binding Value, StringFormat=\{0:C\}}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Classes="cell" Text="{Binding Description}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- =============== Byes & Withdrawals =============== -->
            <TabItem Header="Byes &amp; Withdrawals">
                <ScrollViewer Margin="8">
                    <StackPanel Spacing="16">

                        <StackPanel Spacing="4">
                            <TextBlock Text="All byes and unpaired rounds" FontWeight="SemiBold"/>
                            <Grid ColumnDefinitions="60,60,*,160" Margin="0,0,0,4">
                                <TextBlock Grid.Column="0" Classes="colHeader" Text="Round"/>
                                <TextBlock Grid.Column="1" Classes="colHeader" Text="Pair"/>
                                <TextBlock Grid.Column="2" Classes="colHeader" Text="Name"/>
                                <TextBlock Grid.Column="3" Classes="colHeader" Text="Kind"/>
                            </Grid>
                            <TextBlock Text="None recorded."
                                       Foreground="Gray"
                                       IsVisible="{Binding !AllByes.Count}"/>
                            <ItemsControl ItemsSource="{Binding AllByes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:ByeRow">
                                        <Border Classes="row">
                                            <Grid ColumnDefinitions="60,60,*,160">
                                                <TextBlock Grid.Column="0" Classes="cell" Text="{Binding Round}"/>
                                                <TextBlock Grid.Column="1" Classes="cell" Text="{Binding PairNumber}"/>
                                                <TextBlock Grid.Column="2" Classes="cell" Text="{Binding Name}"/>
                                                <TextBlock Grid.Column="3" Classes="cell" Text="{Binding Kind}" Foreground="DarkBlue"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Players with requested (future) byes" FontWeight="SemiBold"/>
                            <ItemsControl ItemsSource="{Binding Players}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="vm:PlayerRow">
                                        <Border Classes="row"
                                                IsVisible="{Binding RequestedByes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <Grid ColumnDefinitions="60,*,120">
                                                <TextBlock Grid.Column="0" Classes="cell" Text="{Binding PairNumber}"/>
                                                <TextBlock Grid.Column="1" Classes="cell" Text="{Binding Name}"/>
                                                <TextBlock Grid.Column="2" Classes="cell" Text="{Binding RequestedByes}" Foreground="DarkBlue"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>

</UserControl>
