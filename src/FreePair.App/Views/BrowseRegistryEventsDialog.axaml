<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FreePair.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="520"
        x:Class="FreePair.App.Views.BrowseRegistryEventsDialog"
        x:DataType="vm:BrowseRegistryEventsViewModel"
        Title="Browse online events"
        Width="720"
        Height="520"
        MinWidth="560"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel Margin="16" LastChildFill="True">

        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,10">
            <TextBlock Text="Browse online events"
                       FontWeight="SemiBold" FontSize="14"/>
            <Grid ColumnDefinitions="110,*,Auto,*" RowSpacing="4">
                <TextBlock Grid.Column="0" Text="Registry:" VerticalAlignment="Center" Foreground="DimGray"/>
                <ComboBox  Grid.Column="1"
                           ItemsSource="{Binding Registries}"
                           SelectedItem="{Binding SelectedRegistry, Mode=TwoWay}"
                           DisplayMemberBinding="{Binding DisplayName}"
                           HorizontalAlignment="Stretch"/>
                <Button    Grid.Column="2"
                           Content="Refresh"
                           Click="OnRefresh"
                           Margin="12,0,12,0"/>
                <TextBox   Grid.Column="3"
                           Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           Watermark="Filter by name, id, location…"/>
            </Grid>
            <TextBlock Foreground="DarkRed"
                       TextWrapping="Wrap"
                       Text="{Binding ErrorMessage}"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            <TextBlock Text="Loading events…" Foreground="Gray"
                       IsVisible="{Binding IsLoading}"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <TextBlock Foreground="Gray" FontSize="11" VerticalAlignment="Center"
                       Text="Click ▶ on an event to open it (you'll be prompted for the passcode)."/>
            <Button Content="Close" Click="OnCancel" MinWidth="90" IsCancel="True"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding FilteredEvents}"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  AutoGenerateColumns="False">
            <DataGrid.Columns>
                <!-- Per-row open button. Clicking closes the browse
                     dialog with the chosen event so the caller can
                     pop the by-id Open dialog with the event id
                     pre-filled. -->
                <DataGridTemplateColumn Header="" Width="90" CanUserSort="False" CanUserReorder="False" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="▶ Open"
                                    Tag="{Binding}"
                                    Click="OnRowOpenClick"
                                    Padding="8,2"
                                    Margin="2"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    ToolTip.Tip="Open this event (you will be prompted for the passcode)."/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Hyperlink-styled Name column. Clicking the
                     button shells out to the registry's web URL so
                     the TD can read the event description in a
                     browser before committing. Falls back to a
                     plain TextBlock if the registry doesn't expose
                     a public URL (GetEventWebUrl returns null). -->
                <DataGridTemplateColumn Header="Name" Width="320" SortMemberPath="Name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                    Tag="{Binding}"
                                    Click="OnEventNameClick"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="DodgerBlue"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Padding="4,2"
                                    Cursor="Hand"
                                    ToolTip.Tip="Open the event details page in your browser."/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Start"     Binding="{Binding StartDate}" SortMemberPath="StartDate" Width="100"/>
                <DataGridTextColumn Header="End"       Binding="{Binding EndDate}"   SortMemberPath="EndDate"   Width="100"/>
                <DataGridTextColumn Header="Location"  Binding="{Binding Location}"  SortMemberPath="Location"  Width="170"/>
                <DataGridTextColumn Header="Organizer" Binding="{Binding Organizer}" SortMemberPath="Organizer" Width="160"/>
                <DataGridTextColumn Header="Status"    Binding="{Binding Status}"    SortMemberPath="Status"    Width="90"/>

                <!-- Event ID column with an inline copy-to-clipboard
                     icon. Useful when the TD needs to share the id
                     out-of-band (chat, email) without opening a
                     terminal. -->
                <DataGridTemplateColumn Header="ID" Width="240" SortMemberPath="Id">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Id}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding Id}"/>
                                <Button Grid.Column="1"
                                        Content="📋"
                                        Tag="{Binding Id}"
                                        Click="OnCopyEventIdClick"
                                        Padding="4,0"
                                        Margin="4,0,0,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ToolTip.Tip="Copy event ID to clipboard."/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
