<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FreePair.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="520"
        x:Class="FreePair.App.Views.BrowseRegistryEventsDialog"
        x:DataType="vm:BrowseRegistryEventsViewModel"
        Title="Browse online events"
        Width="720"
        Height="520"
        MinWidth="560"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel Margin="16" LastChildFill="True">

        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,10">
            <TextBlock Text="Browse online events"
                       FontWeight="SemiBold" FontSize="14"/>
            <Grid ColumnDefinitions="110,*,Auto,*" RowSpacing="4">
                <TextBlock Grid.Column="0" Text="Registry:" VerticalAlignment="Center" Foreground="DimGray"/>
                <ComboBox  Grid.Column="1"
                           ItemsSource="{Binding Registries}"
                           SelectedItem="{Binding SelectedRegistry, Mode=TwoWay}"
                           DisplayMemberBinding="{Binding DisplayName}"
                           HorizontalAlignment="Stretch"/>
                <Button    Grid.Column="2"
                           Content="Refresh"
                           Click="OnRefresh"
                           Margin="12,0,12,0"/>
                <TextBox   Grid.Column="3"
                           Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                           Watermark="Filter by name, id, location…"/>
            </Grid>
            <TextBlock Foreground="DarkRed"
                       TextWrapping="Wrap"
                       Text="{Binding ErrorMessage}"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            <TextBlock Text="Loading events…" Foreground="Gray"
                       IsVisible="{Binding IsLoading}"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,12,0,0">
            <TextBlock Foreground="Gray" FontSize="11" VerticalAlignment="Center"
                       Text="Click ▶ on an event to open it (you'll be prompted for the passcode)."/>
            <Button Content="Close" Click="OnCancel" MinWidth="90" IsCancel="True"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding FilteredEvents}"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="True"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  AutoGenerateColumns="False">
            <DataGrid.Columns>
                <!-- Per-row open button. Clicking closes the browse
                     dialog with the chosen event so the caller can
                     pop the by-id Open dialog with the event id
                     pre-filled. Distinct from a SelectedItem flow
                     because the row click itself is the action; no
                     separate Open button at the bottom. -->
                <DataGridTemplateColumn Header="" Width="60" CanUserSort="False" CanUserReorder="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="▶ Open"
                                    Tag="{Binding}"
                                    Click="OnRowOpenClick"
                                    Padding="8,2"
                                    Margin="2"
                                    ToolTip.Tip="Open this event (you will be prompted for the passcode)."/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Name"      Binding="{Binding Name}"      SortMemberPath="Name"      Width="*" MinWidth="200"/>
                <DataGridTextColumn Header="Start"     Binding="{Binding StartDate}" SortMemberPath="StartDate" Width="110"/>
                <DataGridTextColumn Header="End"       Binding="{Binding EndDate}"   SortMemberPath="EndDate"   Width="110"/>
                <DataGridTextColumn Header="Location"  Binding="{Binding Location}"  SortMemberPath="Location"  Width="160"/>
                <DataGridTextColumn Header="Organizer" Binding="{Binding Organizer}" SortMemberPath="Organizer" Width="160"/>
                <DataGridTextColumn Header="Status"    Binding="{Binding Status}"    SortMemberPath="Status"    Width="100"/>
                <DataGridTextColumn Header="ID"        Binding="{Binding Id}"        SortMemberPath="Id"        Width="220"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
