<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FreePair.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="780" d:DesignHeight="480"
        x:Class="FreePair.App.Views.PairAllSectionsDialog"
        x:DataType="vm:PairAllSectionsViewModel"
        Title="Pair all sections"
        Width="780"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <StackPanel Margin="20" Spacing="12">

        <TextBlock Text="Pair all sections"
                   FontWeight="SemiBold"
                   FontSize="14"/>

        <TextBlock Text="Pair the next round of every section that's ready in one click. A section is ready when at least 2 players are active, the previous round's results are all in, and more rounds remain. Sections waiting on results, finished, or with too few players are listed for context but skipped."
                   Foreground="Gray"
                   FontSize="11"
                   TextWrapping="Wrap"/>

        <Border Background="#F6F6F6" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="12">
            <StackPanel Spacing="6">
                <Grid ColumnDefinitions="2*,80,80,100,*" Margin="0,0,0,4">
                    <TextBlock Grid.Column="0" Text="Section"      FontWeight="SemiBold" Foreground="DimGray"/>
                    <TextBlock Grid.Column="1" Text="Players"      FontWeight="SemiBold" Foreground="DimGray" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="2" Text="Rounds"       FontWeight="SemiBold" Foreground="DimGray" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="3" Text="Start board"  FontWeight="SemiBold" Foreground="DimGray" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="4" Text="Status"       FontWeight="SemiBold" Foreground="DimGray"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:PairAllSectionRow">
                            <Grid ColumnDefinitions="2*,80,80,100,*" Margin="0,3">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ActivePlayers}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,12,0"
                                           Foreground="Gray"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding ProgressText}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,12,0"
                                           Foreground="Gray"/>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding StartBoard}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,12,0"
                                           Foreground="Gray"/>
                                <StackPanel Grid.Column="4"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding StatusIcon}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding StatusText}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <TextBlock Text="{Binding Summary}"
                   FontSize="12"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"/>
        <TextBlock Text="Tip: edit each section's start board via 🔢 Renumber boards before pairing if you want a different physical board layout."
                   FontSize="11"
                   Foreground="Gray"
                   TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8"
                    Margin="0,8,0,0">
            <Button Content="Cancel"
                    Click="OnCancel"
                    MinWidth="90"
                    IsCancel="True"/>
            <Button Content="Pair ready sections"
                    Click="OnApply"
                    MinWidth="180"
                    IsDefault="True"
                    Background="#0E5DAA"
                    Foreground="White"
                    IsEnabled="{Binding ReadyCount}"/>
        </StackPanel>
    </StackPanel>
</Window>
