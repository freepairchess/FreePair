<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FreePair.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="780" d:DesignHeight="480"
        x:Class="FreePair.App.Views.PairAllSectionsDialog"
        x:DataType="vm:PairAllSectionsViewModel"
        Title="Pair all sections"
        Width="960"
        Height="720"
        MinWidth="720"
        MinHeight="480"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <!-- DockPanel layout so the bottom button row is ALWAYS visible
         no matter how short the window is or how many rows the
         scrollable table contains. Dock=Bottom must come before the
         fill child for Avalonia to reserve space correctly. -->
    <DockPanel Margin="20" LastChildFill="True">

        <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,10">
            <TextBlock Text="Pair all sections"
                       FontWeight="SemiBold"
                       FontSize="14"/>
            <TextBlock Text="Pair the next round of every section that's ready in one click. A section is ready when at least 2 players are active, the previous round's results are all in, and more rounds remain. Sections waiting on results, finished, or with too few players are listed for context but skipped."
                       Foreground="Gray"
                       FontSize="11"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Footer: summary text + buttons. Always visible — never
             scrolls off the bottom even when the table fills. -->
        <StackPanel DockPanel.Dock="Bottom" Spacing="6" Margin="0,10,0,0">
            <TextBlock Text="{Binding Summary}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding ConflictSummary}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Foreground="{Binding HasAnyConflict, Converter={StaticResource ConflictBrush}}"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,4,0,0">
                <Button Content="Use recommended"
                        Command="{Binding UseRecommendedCommand}"
                        MinWidth="160"
                        ToolTip.Tip="Cascade each section's starting board so they stack with no overlap. You can still tweak individual rows after."/>
                <Button Content="Cancel"
                        Click="OnCancel"
                        MinWidth="90"
                        IsCancel="True"/>
                <Button Content="Pair ready sections"
                        Click="OnApply"
                        MinWidth="180"
                        IsDefault="True"
                        Background="#0E5DAA"
                        Foreground="White"
                        IsEnabled="{Binding ReadyCount}"/>
            </StackPanel>
        </StackPanel>

        <!-- Scrollable table fills the middle. -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Border Background="#F6F6F6" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="2*,70,70,140,110,2*" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" Text="Section"      FontWeight="SemiBold" Foreground="DimGray"/>
                        <TextBlock Grid.Column="1" Text="Players"      FontWeight="SemiBold" Foreground="DimGray" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="2" Text="Rounds"       FontWeight="SemiBold" Foreground="DimGray" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="3" Text="Start board"  FontWeight="SemiBold" Foreground="DimGray"/>
                        <TextBlock Grid.Column="4" Text="Range"        FontWeight="SemiBold" Foreground="DimGray"/>
                        <TextBlock Grid.Column="5" Text="Status / conflict" FontWeight="SemiBold" Foreground="DimGray"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Rows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:PairAllSectionRow">
                                <Grid ColumnDefinitions="2*,70,70,140,110,2*" Margin="0,3">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ActivePlayers}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,12,0"
                                               Foreground="Gray"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding ProgressText}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,12,0"
                                               Foreground="Gray"/>
                                    <NumericUpDown Grid.Column="3"
                                                   Value="{Binding StartingBoard, Mode=TwoWay}"
                                                   Minimum="1" Maximum="9999" Increment="1"
                                                   FormatString="0"
                                                   ShowButtonSpinner="True"
                                                   HorizontalAlignment="Stretch"/>
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding BoardRangeText}"
                                               VerticalAlignment="Center"
                                               Foreground="Gray"
                                               Margin="6,0,0,0"/>
                                    <StackPanel Grid.Column="5"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal"
                                                    IsVisible="{Binding !HasConflict}">
                                            <TextBlock Text="{Binding StatusIcon}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding StatusText}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal"
                                                    IsVisible="{Binding HasConflict}">
                                            <TextBlock Text="⚠"
                                                       Foreground="DarkOrange"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding ConflictMessage}"
                                                       Foreground="DarkOrange"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </DockPanel>

    <Window.Resources>
        <vm:BoolToBrushConverter x:Key="ConflictBrush"
                                 TrueBrush="DarkOrange"
                                 FalseBrush="Gray"/>
    </Window.Resources>
</Window>
