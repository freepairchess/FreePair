<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FreePair.App.ViewModels"
             xmlns:core="using:FreePair.Core.Tournaments"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="640"
             x:Class="FreePair.App.Views.TournamentView"
             x:DataType="vm:TournamentViewModel">

    <Design.DataContext>
        <vm:TournamentViewModel/>
    </Design.DataContext>

    <DockPanel Margin="12" LastChildFill="True">

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="➕ New event..."
                        Command="{Binding NewCommand}"
                        IsEnabled="{Binding !IsLoading}"
                        ToolTip.Tip="Create a brand-new tournament and save it as a new .sjson file."/>
                <Button Content="Open tournament..."
                        Command="{Binding OpenCommand}"
                        IsEnabled="{Binding !IsLoading}"/>
                <Button Content="🌐 Open from online…"
                        Command="{Binding OpenFromRegistryCommand}"
                        IsEnabled="{Binding !IsLoading}"
                        ToolTip.Tip="Open a tournament from an online registration system (NA Chess Hub etc.) by event ID + passcode."/>
                <Button Content="🔎 Browse online events…"
                        Command="{Binding BrowseRegistryEventsCommand}"
                        IsEnabled="{Binding !IsLoading}"
                        ToolTip.Tip="List events from an online registration system and pick one to open."/>
                <Button Content="Close"
                        Command="{Binding CloseCommand}"
                        IsVisible="{Binding HasTournament}"/>
                <Button Content="📡 Publish online..."
                        Command="{Binding PublishCommand}"
                        IsVisible="{Binding HasTournament}"
                        ToolTip.Tip="Upload the current .sjson to a publishing destination (NA Chess Hub, …), with optional auto-publish on every pairing update / result entry."/>
                <Button Content="📤 Export USCF report..."
                        Command="{Binding ExportUscfCommand}"
                        IsVisible="{Binding HasTournament}"
                        ToolTip.Tip="Generate the three .DBF files USCF requires for rating submissions (THEXPORT, TSEXPORT, TDEXPORT), prefixed with the event name and saved next to the .sjson."/>
                <Button Content="Export section to TRF..."
                        Command="{Binding ExportTrfCommand}"
                        IsVisible="{Binding HasSelectedSection}"
                        ToolTip.Tip="Export the selected section as a FIDE TRF file (ASCII) for use with BBP or similar pairing engines."/>
                <TextBlock Text="{Binding CurrentFilePath}"
                           Foreground="Gray"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Transient status shown only while a save / publish is
                     in flight (SaveStatus is set while the op is running
                     and cleared on completion). -->
                <TextBlock Text="{Binding SaveStatus}"
                           Foreground="DarkBlue"
                           FontStyle="Italic"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsSaving}"/>
            </StackPanel>

            <!-- Persistent "last saved" + "last published" row, sitting
                 below the main toolbar so a long file path never shoves
                 it off-screen. The "last saved" span is seeded from the
                 file's on-disk mtime on open, then updated after every
                 in-session save. The "last published" span is
                 independent: visible only after a successful publish
                 attempt (HasLastPublishedUrl flips true); its 'NA Chess
                 Hub' word is a hyperlink into the hub's EventFiles
                 page. Both timestamps use yyyy-MM-dd HH:mm:ss local so
                 the date is always visible alongside the time. -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="12"
                        Margin="0,2,0,0">
                <StackPanel Orientation="Horizontal" Spacing="0"
                            IsVisible="{Binding HasLastSavedAt}">
                    <TextBlock Text="last saved at " Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LastSavedAtDisplay}"
                               Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="·" Foreground="Gray" FontSize="11" VerticalAlignment="Center"
                           IsVisible="{Binding HasLastPublishedUrl}"/>
                <StackPanel Orientation="Horizontal" Spacing="0"
                            IsVisible="{Binding HasLastPublishedUrl}">
                    <TextBlock Text="last published to " Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <Button Content="NA Chess Hub"
                            Tag="{Binding LastPublishedUrl}"
                            Click="OnOpenPublishedUrl"
                            Foreground="#0E5DAA"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            FontSize="11"
                            VerticalAlignment="Center"
                            ToolTip.Tip="{Binding LastPublishedUrl}"/>
                    <TextBlock Text=" at " Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LastPublishedAtDisplay}"
                               Foreground="Gray"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Loading..."
                       Foreground="Gray"
                       IsVisible="{Binding IsLoading}"/>

            <Border IsVisible="{Binding HasError}"
                    Background="#FFE8E8"
                    BorderBrush="OrangeRed"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="DarkRed"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <!-- Empty state -->
        <TextBlock DockPanel.Dock="Top"
                   Text="No tournament loaded. Click &quot;Open tournament...&quot; to select a SwissSys .sjson file."
                   Foreground="Gray"
                   Margin="0,24,0,0"
                   IsVisible="{Binding !HasTournament}"/>

        <!-- Tournament workspace -->
        <Grid ColumnDefinitions="260,*"
              IsVisible="{Binding HasTournament}">

            <!-- Left: header + section list -->
            <Border Grid.Column="0"
                    BorderBrush="LightGray"
                    BorderThickness="0,0,1,0"
                    Padding="0,0,8,0">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Top"
                            Command="{Binding ShowEventConfigCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="6"
                            Margin="0,0,0,12"
                            Background="Transparent"
                            BorderThickness="1"
                            BorderBrush="Transparent"
                            ToolTip.Tip="Open event configuration">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#F0F4FF"/>
                                <Setter Property="BorderBrush" Value="#C7D4F2"/>
                            </Style>
                        </Button.Styles>
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding Tournament.Title}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Tournament.LocationSummary}"
                                       Foreground="Gray"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding Tournament.LocationSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <TextBlock Foreground="Gray" FontSize="11">
                                <Run Text="Time control: "/>
                                <Run Text="{Binding Tournament.TimeControl, TargetNullValue='', FallbackValue=''}"/>
                            </TextBlock>
                            <TextBlock Foreground="Gray" FontSize="11">
                                <Run Text="{Binding Tournament.StartDate, TargetNullValue='', FallbackValue=''}"/>
                                <Run Text=" — "/>
                                <Run Text="{Binding Tournament.EndDate, TargetNullValue='', FallbackValue=''}"/>
                            </TextBlock>
                            <TextBlock Text="⚙ Click to edit"
                                       Foreground="#0E5DAA"
                                       FontSize="10"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <TextBlock DockPanel.Dock="Top"
                               Text="SECTIONS"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="Gray"
                               Margin="0,0,0,4"/>

                    <!-- Add-section affordance below the SECTIONS
                         header so the TD has a visible entry point
                         to grow the event after loading or creating
                         it. Opens the SectionFormDialog. -->
                    <Button DockPanel.Dock="Top"
                            Content="➕ Add section"
                            Command="{Binding AddSectionCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="8,4"
                            Margin="0,0,0,6"
                            ToolTip.Tip="Create a new Swiss or round-robin section in this tournament."/>

                    <ListBox ItemsSource="{Binding Sections}"
                             SelectedItem="{Binding SelectedSection}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:SectionViewModel">
                                <!-- Two-row layout: name + stats on the
                                     left, a small lifecycle icon button
                                     docked to the top-right corner.
                                     Buttons are transparent with no
                                     border so they read as icons, not
                                     chrome. Live row shows one button
                                     (soft-delete); soft-deleted row
                                     shows two (undelete + permanently
                                     delete). -->
                                <DockPanel LastChildFill="True" Margin="0,4">
                                    <!-- Up / Down reorder arrows,
                                         docked to the right alongside
                                         the lifecycle icons. Hidden
                                         for soft-deleted sections to
                                         match how other write
                                         operations are gated. Chevron
                                         glyphs (U+E70E up, U+E70D
                                         down). -->
                                    <Button DockPanel.Dock="Right"
                                            Classes="icon-btn"
                                            Foreground="#5A5A5A"
                                            Content="&#xE70D;"
                                            Command="{Binding MoveDownCommand}"
                                            IsVisible="{Binding IsLive}"
                                            ToolTip.Tip="Move this section down."/>
                                    <Button DockPanel.Dock="Right"
                                            Classes="icon-btn"
                                            Foreground="#5A5A5A"
                                            Content="&#xE70E;"
                                            Command="{Binding MoveUpCommand}"
                                            IsVisible="{Binding IsLive}"
                                            ToolTip.Tip="Move this section up."/>
                                    <Button DockPanel.Dock="Right"
                                            Classes="icon-btn"
                                            Foreground="SeaGreen"
                                            Content="&#xE74D;"
                                            Command="{Binding SoftDeleteSectionCommand}"
                                            IsVisible="{Binding IsLive}"
                                            ToolTip.Tip="Soft-delete this section (reversible). Locks it against edits and excludes it from published results."/>
                                    <Button DockPanel.Dock="Right"
                                            Classes="icon-btn"
                                            Foreground="#C62828"
                                            Content="&#xE74D;"
                                            Command="{Binding HardDeleteSectionCommand}"
                                            IsVisible="{Binding IsSoftDeleted}"
                                            ToolTip.Tip="Permanently delete this section. Every player, round, pairing, result, and prize will be discarded and cannot be recovered."/>
                                    <Button DockPanel.Dock="Right"
                                            Classes="icon-btn"
                                            Foreground="#0E5DAA"
                                            Content="&#xE7A7;"
                                            Command="{Binding UndeleteSectionCommand}"
                                            IsVisible="{Binding IsSoftDeleted}"
                                            ToolTip.Tip="Restore this soft-deleted section."/>
                                    <StackPanel Spacing="2">
                                        <!-- Soft-deleted sections get a
                                             strike-through + gray italic
                                             style and a " [deleted]"
                                             suffix so the TD can spot
                                             them at a glance. -->
                                        <TextBlock FontWeight="SemiBold"
                                                   Classes.deleted="{Binding IsSoftDeleted}">
                                            <TextBlock.Styles>
                                                <Style Selector="TextBlock.deleted">
                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                    <Setter Property="Foreground" Value="Gray"/>
                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                </Style>
                                            </TextBlock.Styles>
                                            <Run Text="{Binding Name}"/><Run Text="{Binding TabLabelSuffix}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="Gray">
                                            <Run Text="{Binding PlayerCount}"/>
                                            <Run Text=" players · "/>
                                            <Run Text="{Binding RoundsPlayed}"/>
                                            <Run Text="/"/>
                                            <Run Text="{Binding RoundsPaired}"/>
                                            <Run Text=" rounds"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Right: event-config form OR selected-section content -->
            <Grid Grid.Column="1" Margin="12,0,0,0">
                <ContentControl Content="{Binding EventConfig}"
                                IsVisible="{Binding IsEventConfigSelected}"/>
                <ContentControl Content="{Binding SelectedSection}"
                                IsVisible="{Binding !IsEventConfigSelected}"/>
            </Grid>
        </Grid>

    </DockPanel>

</UserControl>
