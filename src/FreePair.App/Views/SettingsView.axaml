<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FreePair.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="300"
             x:Class="FreePair.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <Design.DataContext>
        <vm:SettingsViewModel/>
    </Design.DataContext>

    <StackPanel Margin="16" Spacing="8">
        <TextBlock Text="Pairing engine binary" FontWeight="SemiBold"/>
        <TextBlock TextWrapping="Wrap" Foreground="Gray">
            <Run Text="FreePair drives all Swiss pairings through the"/>
            <Run Text="BBP Pairings" FontWeight="SemiBold"/>
            <Run Text="engine (FIDE Dutch System) — the only pairing engine FreePair supports. Released installers bundle bbpPairings.exe next to FreePair.App.exe; this field only matters when running from a manual build that didn't include the binary."/>
            <LineBreak/>
            <Run Text="Pairings are bit-for-bit FIDE-compliant for FIDE-rated events. USCF accepts the resulting crosstable for rating submission, but the pairings themselves follow FIDE Rule C.04 (Dutch System), not USCF Rule 27 — most weekend Swisses pair identically; edge cases (color repeats, last-round prize protection) may differ from a strict-USCF tool like SwissSys." FontSize="11"/>
        </TextBlock>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Text="{Binding PairingEngineBinaryPath}"
                     Watermark="Select the pairing engine binary..."/>
            <Button Grid.Column="1"
                    Content="Browse..."
                    Command="{Binding BrowsePairingEngineCommand}"/>
        </Grid>

        <TextBlock Text="Selected file was not found on disk."
                   Foreground="OrangeRed"
                   IsVisible="{Binding PairingEngineBinaryMissing}"/>

        <Separator Margin="0,8"/>

        <TextBlock Text="Display" FontWeight="SemiBold"/>
        <CheckBox Content="Use ASCII-only output (disable Unicode ½ glyphs)"
                  IsChecked="{Binding UseAsciiOnly}"/>
        <TextBlock Text="When off, half-point scores and drawn results render as ½ / ½-½. Changes apply immediately."
                   Foreground="Gray"
                   FontSize="11"
                   TextWrapping="Wrap"/>

        <Separator Margin="0,8"/>

        <TextBlock Text="Online publishing" FontWeight="SemiBold"/>
        <TextBlock Text="Defaults used by the 'Publish online' dialog. Each tournament inherits these values on open and can override them per-event."
                   Foreground="Gray" FontSize="11" TextWrapping="Wrap"/>

        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto">
            <TextBlock Grid.Column="0" Text="NA Chess Hub URL"
                       VerticalAlignment="Center" FontWeight="SemiBold"
                       Margin="0,0,12,0"/>
            <TextBox   Grid.Column="1" Text="{Binding NaChessHubBaseUrl}"
                       Watermark="https://nachesshub.com"/>
        </Grid>

        <CheckBox Content="Auto-publish pairings by default for newly opened tournaments"
                  IsChecked="{Binding AutoPublishPairingsDefault}"/>
        <CheckBox Content="Auto-publish results by default for newly opened tournaments"
                  IsChecked="{Binding AutoPublishResultsDefault}"/>

        <Separator Margin="0,8"/>

        <TextBlock Text="Tournament files" FontWeight="SemiBold"/>
        <TextBlock Foreground="Gray" FontSize="11" TextWrapping="Wrap"
                   Text="Root folder under which FreePair creates one subfolder per event (.sjson + any exported PDFs for that event land inside together). Leave blank to use the default: Documents/FreePairEvents."/>
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Text="{Binding TournamentsRootFolder}"
                     Watermark="Leave blank for Documents/FreePairEvents"/>
            <Button Grid.Column="1"
                    Content="Browse..."
                    Command="{Binding BrowseTournamentsRootFolderCommand}"/>
        </Grid>
        <TextBlock Foreground="Gray" FontSize="11">
            <Run Text="Effective folder: "/>
            <Run Text="{Binding EffectiveTournamentsRootFolder}" FontStyle="Italic"/>
        </TextBlock>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Save" Command="{Binding SaveCommand}"/>
        </StackPanel>
        <TextBlock Text="{Binding StatusMessage}" Foreground="Gray"/>
    </StackPanel>

</UserControl>
